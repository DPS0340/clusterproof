{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DPS0340/clusterproof/schemas/ruleset-v1.schema.json",
  "title": "ClusterProof ruleset catalog contract v1",
  "description": "Catalog rendered by `clusterproof ruleset show --format json`. Minor releases may add optional fields and new rules; rule IDs are never removed or reused within a schema major version.",
  "type": "object",
  "required": ["schema_version", "id", "version", "kubernetes", "rules"],
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "kubernetes": {
      "type": "object",
      "required": ["kubernetes_minor", "supported_minors"],
      "properties": {
        "kubernetes_minor": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
        "supported_minors": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" }
        }
      }
    },
    "pss_coverage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["profile", "control", "status", "rule_ids"],
        "properties": {
          "profile": { "enum": ["baseline", "restricted"] },
          "control": { "type": "string", "minLength": 1 },
          "status": { "enum": ["complete", "partial"] },
          "rule_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "note": { "type": "string" }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "category", "description", "remediation", "os", "control_refs", "sources"],
        "properties": {
          "id": { "type": "string", "pattern": "^CP-[A-Z0-9]+-[0-9]{3}$" },
          "title": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "remediation": { "type": "string", "minLength": 1 },
          "os": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["linux", "windows"] }
          },
          "control_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "version", "url", "relationship"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "version": { "type": "string", "minLength": 1 },
                "url": { "type": "string", "pattern": "^https://" },
                "relationship": { "enum": ["aligned", "supplemental"] }
              }
            }
          }
        }
      }
    }
  }
}
