{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DPS0340/clusterproof/schemas/exceptions-v1.schema.json",
  "title": "ClusterProof repository exception file v1",
  "description": "Repository-owned finding suppressions. Every entry requires an exact rule and target, an owner, a reason, and a UTC expiry date. Unknown fields are rejected by the CLI.",
  "type": "object",
  "required": ["schema_version", "exceptions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "exceptions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "required": ["rule", "target", "owner", "reason", "expires"],
        "additionalProperties": false,
        "properties": {
          "rule": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "target": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "owner": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "reason": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "expires": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    }
  }
}
