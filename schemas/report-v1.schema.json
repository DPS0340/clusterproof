{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DPS0340/clusterproof/schemas/report-v1.schema.json",
  "title": "ClusterProof report contract v1",
  "description": "Canonical scan report. Minor releases may add optional fields; removing or retyping a field requires a new schema major version and a migration note.",
  "type": "object",
  "required": ["schema_version", "generated_at", "target", "tool_version", "inputs", "findings", "summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "target": { "type": "string", "minLength": 1 },
    "tool_version": { "type": "string", "minLength": 1 },
    "ruleset": {
      "type": "object",
      "required": ["id", "version", "rules_evaluated"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "rules_evaluated": { "type": "integer", "minimum": 1 }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "title", "description", "remediation", "source", "target", "location", "evidence", "control_refs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["info", "low", "medium", "high", "critical"] },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "remediation": { "type": "string" },
          "source": { "type": "string", "minLength": 1 },
          "target": { "type": "string" },
          "location": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "document": { "type": "integer" },
              "line": { "type": "integer" },
              "resource": { "type": "string" },
              "container": { "type": "string" }
            }
          },
          "evidence": {
            "type": "object",
            "properties": {
              "observed": { "type": "string" },
              "expected": { "type": "string" }
            }
          },
          "control_refs": { "type": "array", "items": { "type": "string" } },
          "external_refs": { "type": "object", "additionalProperties": { "type": "string" } }
        }
      }
    },
    "suppressed_findings": {
      "description": "Added in v0.4 as an optional field; absent when no exception file is used.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule", "severity", "target", "owner", "reason", "expires", "location"],
        "properties": {
          "rule": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["info", "low", "medium", "high", "critical"] },
          "target": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "expires": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "location": { "type": "object" }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["critical", "high", "medium", "low", "info"],
      "properties": {
        "critical": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 },
        "info": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
